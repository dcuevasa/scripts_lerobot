   "source": [
    "import re\n",
    "import glob\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "_pattern = re.compile(\n",
    "    r\"step:(\\S+)\\s+smpl:(\\S+)\\s+ep:(\\d+)\\s+epch:([\\d.]+)\\s+\"\n",
    "    r\"loss:([\\d.]+)\\s+grdn:([\\d.]+)\\s+lr:([\\de.\\-]+)\"\n",
    ")\n",
    "\n",
    "def parse_log(log_file):\n",
    "    records = []\n",
    "    with open(log_file, encoding=\"utf-8\") as f:\n",
    "        for line in f:\n",
    "            m = _pattern.search(line)\n",
    "            if m:\n",
    "                step_str = m.group(1).replace(\"K\", \"000\")\n",
    "                records.append({\n",
    "                    \"step\":      int(step_str),\n",
    "                    \"loss\":      float(m.group(5)),\n",
    "                    \"grad_norm\": float(m.group(6)),\n",
    "                    \"lr\":        float(m.group(7)),\n",
    "                })\n",
    "    return pd.DataFrame(records)\n",
    "\n",
    "log_files = sorted(glob.glob(\\"training-logs-305/training_logs_*.txt\\"))\n",
    "print(\"Archivos encontrados:\", log_files)\n",
    "\n",
    "fig, axes = plt.subplots(3, 1, figsize=(14, 10), sharex=False)\n",
    "\n",
    "for log_file in log_files:\n",
    "    df = parse_log(log_file)\n",
    "    if df.empty:\n",
    "        print(f\"Sin datos: {log_file}\")\n",
    "        continue\n",
    "    label = log_file.replace(\"training_logs_\", \"\").replace(\".txt\", \"\")\n",
    "    axes[0].plot(df[\"step\"], df[\"loss\"],      marker=\"o\", ms=2, label=label)\n",
    "    axes[1].plot(df[\"step\"], df[\"grad_norm\"], marker=\"o\", ms=2, label=label)\n",
    "    axes[2].plot(df[\"step\"], df[\"lr\"],        marker=\"o\", ms=2, label=label)\n",
    "\n",
    "axes[0].set_ylabel(\"Loss\");       axes[0].set_title(\"Curvas de Aprendizaje - 305eps\"); axes[0].grid(True); axes[0].legend()\n",
    "axes[1].set_ylabel(\"Grad Norm\");  axes[1].grid(True); axes[1].legend()\n",
    "axes[2].set_ylabel(\"Learning Rate\"); axes[2].set_xlabel(\"Step\"); axes[2].grid(True); axes[2].legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"all_runs_curves.png\", dpi=150)\n",
    "plt.show()"
   ]
  }
