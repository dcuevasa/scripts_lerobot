    "import re\n",
    "import glob\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Patrón para las líneas de métricas:\n",
    "# step:22K smpl:349K ep:358 epch:1.17 loss:0.008 grdn:0.181 lr:2.0e-05\n",
    "_pattern = re.compile(\n",
    "    r\"step:(\\S+)\\s+smpl:(\\S+)\\s+ep:(\\d+)\\s+epch:([\\d.]+)\\s+\"\n",
    "    r\"loss:([\\d.]+)\\s+grdn:([\\d.]+)\\s+lr:([\\de.\\-]+)\"\n",
    ")\n",
    "\n",
    "def parse_log(log_file):\n",
    "    \"\"\"Parsea un archivo de log de entrenamiento y retorna un DataFrame.\"\"\"\n",
    "    records = []\n",
    "    with open(log_file, encoding=\"utf-8\") as f:\n",
    "        for line in f:\n",
    "            m = _pattern.search(line)\n",
    "            if m:\n",
    "                step_str = m.group(1).replace(\"K\", \"000\")\n",
    "                records.append({\n",
    "                    \"step\": int(step_str),\n",
    "                    \"samples\": m.group(2).replace(\"K\", \"000\"),\n",
    "                    \"epoch\": float(m.group(4)),\n",
    "                    \"loss\": float(m.group(5)),\n",
    "                    \"grad_norm\": float(m.group(6)),\n",
    "                    \"lr\": float(m.group(7)),\n",
    "                })\n",
    "    return pd.DataFrame(records)\n",
    "\n",
    "def plot_learning_curves(df, title=\"Curvas de Aprendizaje\", save_path=None):\n",
    "    \"\"\"Grafica las curvas de aprendizaje a partir de un DataFrame.\"\"\"\n",
    "    fig, axes = plt.subplots(3, 1, figsize=(12, 10), sharex=True)\n",
    "\n",
    "    axes[0].plot(df[\"step\"], df[\"loss\"], marker=\"o\", ms=3)\n",
    "    axes[0].set_ylabel(\"Loss\")\n",
    "    axes[0].set_title(title)\n",
    "    axes[0].grid(True)\n",
    "\n",
    "    axes[1].plot(df[\"step\"], df[\"grad_norm\"], color=\"orange\", marker=\"o\", ms=3)\n",
    "    axes[1].set_ylabel(\"Gradient Norm\")\n",
    "    axes[1].grid(True)\n",
    "\n",
    "    axes[2].plot(df[\"step\"], df[\"lr\"], color=\"green\", marker=\"o\", ms=3)\n",
    "    axes[2].set_ylabel(\"Learning Rate\")\n",
    "    axes[2].set_xlabel(\"Step\")\n",
    "    axes[2].grid(True)\n",
    "\n",
    "    plt.tight_layout()\n",
    "    if save_path:\n",
    "        plt.savefig(save_path, dpi=150)\n",
    "    plt.show()\n",
    "\n",
    "print(\"Funciones cargadas correctamente.\")"
   ]
  },
